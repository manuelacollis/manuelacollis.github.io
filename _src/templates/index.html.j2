{% extends "_layout.html.j2" %}
{% block content %}
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div>
          <div class="portrait">
            <img src="{{ person.portrait }}" alt="Portrait of {{ person.name }}" />
          </div>
        </div>
        <div>
          <span class="eyebrow">{{ home.hero_eyebrow }}</span>
          <h1>{{ person.name }}</h1>
          <p class="lede">
            {{ home.hero_lede }}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about">
    <div class="container content-narrow">
      <div class="section-title">About</div>
      <div class="prose">
        {{ home.about_html | safe }}
      </div>
    </div>
  </section>

  <!-- CONNECT -->
  <section id="connect">
    <div class="container content-narrow">
      <div class="section-title">Connect</div>

      <ul class="profile-links profile-links-lg" aria-label="Academic and professional profiles">
        <li>
          <a class="js-email" data-u="{{ email_u }}" data-d="{{ email_d }}" href="#">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1zm1 2.4V18h16V7.4l-8 5.5-8-5.5zm.6-.4L12 11.7 19.4 7H4.6z"/></svg>
            <span>Email</span>
          </a>
        </li>
        <li>
          <a href="{{ profiles.scholar }}" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M12 2 1 9l4 2.62V18l7 4 7-4v-6.38L21 9zm0 2.27 7.5 4.73L12 13.73 4.5 9zM6 12.85l6 3.79 6-3.79V17l-6 3.43L6 17z"/></svg>
            <span>Google Scholar</span>
          </a>
        </li>
        <li>
          <a href="{{ profiles.linkedin }}" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M4.98 3.5a2.5 2.5 0 1 1-.02 5.001A2.5 2.5 0 0 1 4.98 3.5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.29-.02-2.95-1.8-2.95-1.8 0-2.07 1.4-2.07 2.86V21h-4z"/></svg>
            <span>LinkedIn</span>
          </a>
        </li>
        <li>
          <a href="{{ profiles.github }}" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56 0-.27-.01-1-.02-1.96-3.2.69-3.88-1.54-3.88-1.54-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.25 3.34.95.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.27-5.24-5.66 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.17a10.92 10.92 0 0 1 5.76 0c2.2-1.48 3.16-1.17 3.16-1.17.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.07 0 4.4-2.69 5.36-5.26 5.65.41.36.78 1.06.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.21.67.8.55C20.22 21.39 23.5 17.07 23.5 12 23.5 5.65 18.35.5 12 .5z"/></svg>
            <span>GitHub</span>
          </a>
        </li>
      </ul>

      {% if contact_tiles %}
      <div class="contact-block" style="margin-top: 36px;">
        {% for tile in contact_tiles %}
        <div class="contact-item">
          <div class="label">{{ tile.label }}</div>
          <div class="value">
            {%- if tile.get('type') == 'email' -%}
              <a class="js-email" data-u="{{ email_u }}" data-d="{{ email_d }}" data-show="address" href="#">{{ email_fallback }}</a>
            {%- else -%}
              {{ tile.get('value_html', '') | safe }}
            {%- endif -%}
          </div>
        </div>
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </section>

  <!-- EXPLORE — primary CTAs into the Research and CV pages -->
  <section id="explore" class="explore">
    <div class="container content-narrow">
      <div class="cta-grid">
        <a class="cta-card" href="research.html">
          <div class="cta-label">Research</div>
          <div class="cta-desc">Publications, working papers, and selected work in progress.</div>
          <div class="cta-arrow" aria-hidden="true">&rarr;</div>
        </a>
        <a class="cta-card" href="cv.html">
          <div class="cta-label">CV</div>
          <div class="cta-desc">Full curriculum vitae &mdash; education, positions, teaching, and service.</div>
          <div class="cta-arrow" aria-hidden="true">&rarr;</div>
        </a>
      </div>
    </div>
  </section>
{% endblock %}
