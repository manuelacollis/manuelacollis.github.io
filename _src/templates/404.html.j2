{% extends "_layout.html.j2" %}
{% block content %}
  {# Smart case-mismatch redirect. If /WTA or /Wta hits 404, auto-jump to /wta. #}
  <script>
  (function () {
    var known = {{ known_slugs | tojson }};
    var seg = window.location.pathname.replace(/^\/+|\/+$/g, "").split("/")[0];
    if (!seg) return;
    var lower = seg.toLowerCase();
    if (seg !== lower && known.indexOf(lower) !== -1) {
      window.location.replace("/" + lower + "/" + window.location.search + window.location.hash);
    }
  })();
  </script>

  <section class="hero" style="padding-top: 96px;">
    <div class="container content-narrow" style="text-align: center;">
      <span class="eyebrow">404 &middot; Page not found</span>
      <h1 style="margin-top: 14px;">This page doesn&rsquo;t exist.</h1>
      <p class="lede" style="max-width: 540px; margin-left: auto; margin-right: auto;">
        The address may be mistyped, or it may have moved when the site was rebuilt
        for Carnegie Mellon. Try one of the pages below.
      </p>

      <div class="cta-grid" style="margin-top: 36px; max-width: 640px; margin-left: auto; margin-right: auto; text-align: left;">
        <a class="cta-card" href="index.html">
          <div class="cta-label">Home</div>
          <div class="cta-desc">About me and how to get in touch.</div>
          <div class="cta-arrow" aria-hidden="true">&rarr;</div>
        </a>
        <a class="cta-card" href="research.html">
          <div class="cta-label">Research</div>
          <div class="cta-desc">Publications, working papers, and selected work in progress.</div>
          <div class="cta-arrow" aria-hidden="true">&rarr;</div>
        </a>
      </div>
    </div>
  </section>
{% endblock %}
